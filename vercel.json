{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/downloads", "destination": "/downloads.html" },
    { "source": "/((?!api|images|font|fonts|assets).*)$", "destination": "/index.html" }
  ]
}
